# PHP upload limits (shared hosting override)
<IfModule mod_php.c>
    php_value upload_max_filesize 128M
    php_value post_max_size 140M
    php_value memory_limit 256M
    php_value max_execution_time 300
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 128M
    php_value post_max_size 140M
    php_value memory_limit 256M
    php_value max_execution_time 300
</IfModule>

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Social media preview botlarına izin ver (WhatsApp, Facebook, Twitter)
    RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|WhatsApp|Twitterbot|LinkedInBot|Slackbot|TelegramBot) [NC]
    RewriteRule ^ - [E=social_bot:1,L]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Canonical domain: force https + non-www for production.
    RewriteCond %{HTTP_HOST} ^www\.gruptalepleri\.com$ [NC,OR]
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP_HOST} ^(www\.)?gruptalepleri\.com$ [NC]
    RewriteRule ^ https://gruptalepleri.com%{REQUEST_URI} [L,R=301]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
